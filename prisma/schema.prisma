generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspacePlan {
  FREE
  PRO
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ConnectionStatus {
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED
}

enum ConnectionProvider {
  GMAIL
  SLACK
  GOOGLE_DRIVE
  GOOGLE_CALENDAR
  GITHUB
  CUSTOM
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  role          UserRole @default(MEMBER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ownedWorkspaces      Workspace[]
  memberships          WorkspaceMember[]
  connections          Connection[]
  forecastProjects     ForecastProject[]
  contributedKnowledge KnowledgeRecord[] @relation("ContributedKnowledge")
  createdInvites       WorkspaceInvite[] @relation("InviteCreator")

  @@map("users")
}

model Workspace {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  ownerId         String
  plan            WorkspacePlan @default(FREE)
  anthropicApiKey String?
  openaiApiKey    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  owner              User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members            WorkspaceMember[]
  connections        Connection[]
  knowledgeRecords   KnowledgeRecord[]
  entities           Entity[]
  canonicalDocuments CanonicalDocument[]
  ingestionLogs      IngestionLog[]
  agentQueries       AgentQuery[]
  auditLogs          AuditLog[]
  forecastProjects   ForecastProject[]
  invites            WorkspaceInvite[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String     @id @default(uuid())
  workspaceId String
  userId      String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Connection {
  id            String             @id @default(uuid())
  workspaceId   String
  provider      ConnectionProvider
  status        ConnectionStatus   @default(ACTIVE)
  accessToken   String?
  refreshToken  String?
  tokenExpiry   DateTime?
  scope         String?
  accountEmail  String?
  lastSyncAt    DateTime?
  recordsSynced Int                @default(0)
  errorMessage  String?
  config        Json               @default("{}")
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])

  @@unique([workspaceId, provider, createdById])
  @@map("connections")
}

model KnowledgeRecord {
  id              String   @id @default(uuid())
  workspaceId     String
  sourceSystem    String
  sourceId        String
  contentType     String
  rawContent      String
  summary         String?
  entities        Json     @default("{}")
  createdAt       DateTime @default(now())
  ingestedAt      DateTime @default(now())
  threadId        String?
  parentId        String?
  sensitivity     String   @default("internal")
  metadata        Json     @default("{}")
  contributedById String?

  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contributedBy  User?              @relation("ContributedKnowledge", fields: [contributedById], references: [id])
  parent         KnowledgeRecord?   @relation("RecordHierarchy", fields: [parentId], references: [id])
  children       KnowledgeRecord[]  @relation("RecordHierarchy")
  entityMentions EntityMention[]

  @@unique([workspaceId, sourceSystem, sourceId, contributedById])
  @@map("knowledge_records")
}

model Entity {
  id             String   @id @default(uuid())
  workspaceId    String
  type           String
  canonicalName  String
  aliases        String[] @default([])
  identifiers    Json     @default("{}")
  organizationId String?
  role           String?
  firstSeen      DateTime?
  lastSeen       DateTime?
  mentionCount   Int      @default(0)
  metadata       Json     @default("{}")

  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  organization Entity?         @relation("OrgHierarchy", fields: [organizationId], references: [id])
  members      Entity[]        @relation("OrgHierarchy")
  mentions     EntityMention[]

  @@unique([workspaceId, canonicalName])
  @@map("entities")
}

model EntityMention {
  entityId    String
  recordId    String
  mentionText String
  confidence  Float  @default(1.0)

  entity Entity          @relation(fields: [entityId], references: [id], onDelete: Cascade)
  record KnowledgeRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@id([entityId, recordId])
  @@map("entity_mentions")
}

model CanonicalDocument {
  id             String    @id @default(uuid())
  workspaceId    String
  docType        String
  title          String
  content        String
  version        Int       @default(1)
  priorityWeight Int
  effectiveFrom  DateTime
  supersededAt   DateTime?
  approvedBy     String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("canonical_documents")
}

model IngestionLog {
  id               String    @id @default(uuid())
  workspaceId      String
  sourceSystem     String
  status           String
  recordsProcessed Int       @default(0)
  recordsCreated   Int       @default(0)
  recordsUpdated   Int       @default(0)
  errorMessage     String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  metadata         Json      @default("{}")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("ingestion_logs")
}

model AgentQuery {
  id                 String   @id @default(uuid())
  workspaceId        String
  queryText          String
  routedTo           String
  responseText       String?
  canonicalValidated Boolean  @default(false)
  confidenceScore    Float?
  userId             String?
  feedback           String?
  createdAt          DateTime @default(now())
  responseTimeMs     Int?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("agent_queries")
}

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String
  timestamp   DateTime @default(now())
  userId      String?
  action      String
  resource    String
  resourceId  String?
  details     Json     @default("{}")
  ipAddress   String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model ForecastProject {
  id                  String    @id @default(uuid())
  workspaceId         String
  name                String
  status              String    @default("prompt")
  sponsorName         String?
  sponsorBrief        String?
  rightsHolder        String?
  market              String?
  blueprint           Json?
  blueprintApprovedAt DateTime?
  insightsData        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdById         String

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User              @relation(fields: [createdById], references: [id])
  insights  ForecastInsight[]

  @@map("forecast_projects")
}

model ForecastInsight {
  id          String @id @default(uuid())
  projectId   String
  category    String
  title       String
  description String
  chartType   String
  data        Json
  metadata    Json   @default("{}")

  project ForecastProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("forecast_insights")
}

model WorkspaceInvite {
  id          String     @id @default(uuid())
  workspaceId String
  email       String?
  token       String     @unique @default(uuid())
  role        MemberRole @default(MEMBER)
  createdById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation("InviteCreator", fields: [createdById], references: [id])

  @@map("workspace_invites")
}
